generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  PROJECT_MANAGER
  MEMBER
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ON_HOLD
  CANCELLED
}

enum ProjectHealth {
  ON_TRACK
  LATE
  AT_RISK
  BLOCKED
  CANCELLED
  COMPLETED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

model Tag {
  id        String   @id @default(cuid())
  name      String
  color     String   // couleur hex ex: #3b82f6
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects Project[] @relation("ProjectTags")
}

model WaveTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  isDefault   Boolean  @default(false)
  createdById String
  createdBy   User     @relation("CreatedWaveTemplates", fields: [createdById], references: [id])
  milestones  WaveTemplateMilestone[]
  waves       Wave[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WaveTemplateMilestone {
  id         String              @id @default(cuid())
  name       String
  owner      String              @default("Consentio")
  order      Int                 @default(0)
  offsetDays Int                 @default(0)
  templateId String
  template   WaveTemplate        @relation(fields: [templateId], references: [id], onDelete: Cascade)
  tasks      WaveTemplateTask[]
}

model WaveTemplateTask {
  id           String                @id @default(cuid())
  name         String
  owner        String                @default("Consentio")
  order        Int                   @default(0)
  durationDays Int                   @default(0)
  milestoneId  String
  milestone    WaveTemplateMilestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      Role     @default(MEMBER)
  position  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  managedProjects      Project[]        @relation("ProjectManager")
  ownedTasks           Task[]           @relation("TaskOwner")
  createdTemplates     ProjectTemplate[]
  comments             TaskComment[]    @relation("CommentAuthor")
  uploadedFiles        TaskFile[]       @relation("FileUploader")
  managedWaves         Wave[]           @relation("WaveManager")
  createdWaveTemplates WaveTemplate[]   @relation("CreatedWaveTemplates")
}

model ProjectTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy   User   @relation(fields: [createdById], references: [id])
  createdById String

  milestones TemplateMilestone[]
  projects   Project[]
}

model TemplateMilestone {
  id          String  @id @default(cuid())
  name        String
  description String?
  order       Int     @default(0)
  offsetDays  Int     @default(0)

  template   ProjectTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  templateId String

  tasks TemplateTask[]
}

model TemplateTask {
  id           String  @id @default(cuid())
  name         String
  description  String?
  order        Int     @default(0)
  durationDays Int     @default(1)

  milestone   TemplateMilestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  milestoneId String
}

model Project {
  id          String        @id @default(cuid())
  name        String
  description String?
  status      ProjectStatus @default(ACTIVE)
  health      ProjectHealth @default(ON_TRACK)
  summary     String?
  startDate   DateTime
  endDate     DateTime
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  manager    User   @relation("ProjectManager", fields: [managerId], references: [id])
  managerId  String
  template   ProjectTemplate? @relation(fields: [templateId], references: [id])
  templateId String?

  milestones Milestone[]
  tags       Tag[]      @relation("ProjectTags")
}

model Milestone {
  id          String     @id @default(cuid())
  name        String
  description String?
  dueDate     DateTime
  status      TaskStatus @default(TODO)
  order       Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String

  tasks Task[]
}

model Task {
  id          String     @id @default(cuid())
  name        String
  description String?
  status      TaskStatus @default(TODO)
  dueDate     DateTime
  order       Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  milestone   Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  milestoneId String
  owner       User?     @relation("TaskOwner", fields: [ownerId], references: [id])
  ownerId     String?

  comments TaskComment[]
  files    TaskFile[]
}

model TaskComment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task     Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId   String
  author   User   @relation("CommentAuthor", fields: [authorId], references: [id])
  authorId String
}

// ─── Flywheel Activation ─────────────────────────────────────────────────────

model Wave {
  id          String        @id @default(cuid())
  name        String
  clientName  String
  status      String        @default("ACTIVE")   // ACTIVE | COMPLETED | ON_HOLD | CANCELLED
  startDate   DateTime
  endDate     DateTime
  summary     String?
  managerId   String
  manager     User          @relation("WaveManager", fields: [managerId], references: [id])
  templateId  String?
  template    WaveTemplate? @relation(fields: [templateId], references: [id])
  milestones  WaveMilestone[]
  suppliers   WaveSupplier[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model WaveMilestone {
  id        String     @id @default(cuid())
  waveId    String
  wave      Wave       @relation(fields: [waveId], references: [id], onDelete: Cascade)
  name      String
  owner     String     @default("Consentio")   // Consentio | Client | Fournisseurs
  order     Int        @default(0)
  startDate DateTime?
  dueDate   DateTime
  status    String     @default("TODO")        // TODO | IN_PROGRESS | DONE
  tasks     WaveTask[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model WaveTask {
  id          String        @id @default(cuid())
  milestoneId String
  milestone   WaveMilestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  name        String
  owner       String        @default("Consentio")
  order       Int           @default(0)
  startDate   DateTime?
  dueDate     DateTime
  status      String        @default("TODO")
  pctComplete Float         @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model WaveSupplier {
  id                String   @id @default(cuid())
  waveId            String
  wave              Wave     @relation(fields: [waveId], references: [id], onDelete: Cascade)
  supplierName      String
  supplierCode      String?
  email             String?
  firstName         String?
  lastName          String?
  phone             String?
  language          String?
  status            String   @default("NEW")           // NEW | ALREADY_HAS_WS | NOT_NEW | IN_HUBSPOT_ONLY
  workspaceId       String?
  action            String   @default("TO_CONTACT")    // TO_CONTACT | NO_NEED | CONNECTED | ATTEMPTED
  comments          String?
  accountCreated    Boolean  @default(false)
  registeredWebinar Boolean  @default(false)
  assistedWebinar   Boolean  @default(false)
  configured        Boolean  @default(false)
  productFamilies   String[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model TaskFile {
  id           String   @id @default(cuid())
  name         String
  url          String
  size         Int
  mimeType     String?
  createdAt    DateTime @default(now())

  task         Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId       String
  uploadedBy   User   @relation("FileUploader", fields: [uploadedById], references: [id])
  uploadedById String
}
